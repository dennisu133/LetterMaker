# LetterMaker Backend Configuration
# Copy this file to .env and adjust values as needed

# CORS configuration
# Comma-separated list of allowed origins for cross-origin requests
# Examples:
#   - "http://localhost:5173,http://127.0.0.1:5173" (development)
#   - "https://yourdomain.com" (production, single origin)
#   - "*" (allow all origins - NOT recommended for production)
#   - "none" (disable CORS - use when nginx handles it)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gin mode: "debug", "release", or "test"
# Use "release" in production to disable debug logging
GIN_MODE=debug

# Server settings
HOST=127.0.0.1
PORT=8080

# Trusted proxies (comma-separated list, e.g., "127.0.0.1,192.168.1.1")
# Set to "none" or leave empty to trust no proxies
TRUSTED_PROXIES=127.0.0.1

# Rate limiting configuration
# Requests per second per IP (0.2 = 1 request per 5 seconds sustained)
RATE_LIMIT_RPS=0.2
# Burst size (tokens) - allows short bursts above the sustained rate
RATE_LIMIT_BURST=2
# How long to keep rate limit entries for inactive IPs
RATE_LIMIT_TTL=15m
# How often to clean up expired rate limit entries
RATE_LIMIT_CLEANUP=2m

# Validation limits
# Maximum length for short input fields (salutation, closing, names)
MAX_INPUT_LEN=100
# Maximum length for longer text fields (subject, signature, addresses)
MAX_TEXT_AREA_LEN=200
# Maximum character length for letter content (ProseMirror JSON)
MAX_CONTENT_LEN=10000
# Maximum stamp PDF file size in bytes (512 KiB)
MAX_STAMP_BYTES=524288
# Minimum stamp PDF file size in bytes (1 KiB)
MIN_STAMP_BYTES=1024

# Concurrency limiting (semaphore)
# Maximum number of concurrent PDF compilations
MAX_CONCURRENT_COMPILES=2

# Temporary directory for LaTeX compilation
TMP_DIR=tmp

# Maximum time allowed for PDF compilation (e.g., "30s", "1m")
COMPILE_TIMEOUT=30s

# Maximum request body size in bytes (5 MiB default)
MAX_REQUEST_BYTES=5242880
